# Anthropic — used for Claude Haiku 4.5 calls. Use a V2-specific key so spend is tracked separately from V1.
ANTHROPIC_API_KEY=

# Supabase project: crith-v2
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Free tier monthly limit for /api/analyze-response. Counts only requests that hit Claude
# (trigger-gate skips don't count; parse_error and Claude API errors do — they spent tokens).
FREE_RESPONSE_ANALYSES_MONTHLY_LIMIT=10

# Brave Search API — used by /api/verify-claim to verify factual claims surfaced
# by the claim extractor. Free tier: 2000 queries/month.
# Sign up at https://api.search.brave.com.
BRAVE_API_KEY=

# Stripe — used by /api/stripe-webhook to flip profiles.is_pro on
# checkout.session.completed / customer.subscription.deleted events.
# STRIPE_SECRET_KEY: server-side secret (sk_live_... or sk_test_...).
# STRIPE_WEBHOOK_SECRET: signing secret for the specific webhook endpoint,
# from Stripe Dashboard → Developers → Webhooks → Add endpoint.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
